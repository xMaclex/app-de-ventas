@model IEnumerable<ventaapp.Models.SecuenciaNcf>

@{
    ViewData["Title"] = "Gestión de Comprobantes Fiscales (NCF)";
}

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-file-earmark-ruled me-2" style="color:#4f8ef7;"></i>
                Secuencias NCF
            </h2>
            <small class="text-muted">Gestión de comprobantes fiscales para la DGII</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Crear" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-circle me-1"></i> Nueva Secuencia
            </a>
            <a asp-controller="Ajustes" asp-action="Editar" class="btn btn-outline-secondary rounded-pill px-3">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <!-- Alertas de éxito / error -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Alertas de secuencias críticas -->
    @{
        var alertas = Model.Where(s => s.Activa && (s.CercaDeAgotarse || s.Vencida)).ToList();
    }
    @if (alertas.Any())
    {
        <div class="alert alert-warning shadow-sm mb-4">
            <h6 class="fw-bold mb-2"><i class="bi bi-exclamation-triangle-fill me-1"></i> Atención requerida</h6>
            <ul class="mb-0">
                @foreach (var a in alertas)
                {
                    <li>
                        <strong>@a.Descripcion</strong>:
                        @if (a.Vencida)
                        {
                            <span>vencida el @a.FechaVencimiento.ToString("dd/MM/yyyy"). Renueve la secuencia.</span>
                        }
                        else
                        {
                            <span>quedan solo <strong>@a.Disponibles</strong> comprobantes disponibles.</span>
                        }
                    </li>
                }
            </ul>
        </div>
    }

    <!-- Tabla de secuencias -->
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-file-earmark-x display-3 d-block mb-3"></i>
            <p class="fs-5">No hay secuencias NCF configuradas.</p>
            <a asp-action="Crear" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-circle me-1"></i> Crear primera secuencia
            </a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tipo</th>
                                <th class="text-center">Rango</th>
                                <th class="text-center">ultimo</th>
                                <th class="text-center">Actual</th>
                                <th class="text-center">Disponibles</th>
                                <th class="text-center">Uso</th>
                                <th class="text-center">Vencimiento</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model)
                            {
                                <tr class="@(s.Vencida || s.Agotada ? "table-danger" : s.CercaDeAgotarse ? "table-warning" : "")">
                                    <td>
                                        <span class="fw-semibold">@s.Descripcion</span>
                                    </td>
                                    <td class="text-center text-muted small">
                                        @s.NumeroInicial.ToString("D10") – @s.NumeroFinal.ToString("D10")
                                    </td>
                                    <td class="text-center">
                                        <code>@s.TipoComprobante@s.NumeroActual.ToString("D10")</code>
                                    </td>
                                    <td class="text-center">
                                        <code>@s.TipoComprobante@s.UlitmoNumero.ToString("D10")</code>
                                    </td>
                                    <td class="text-center fw-bold">@s.Disponibles.ToString("N0")</td>
                                    <td class="text-center" style="min-width:120px;">
                                        <div class="progress" style="height:8px;">
                                            <div class="progress-bar @(s.PorcentajeUsado >= 90 ? "bg-danger" : s.PorcentajeUsado >= 75 ? "bg-warning" : "bg-success")"
                                                 style="width:@s.PorcentajeUsado%"></div>
                                        </div>
                                        <small class="text-muted">@s.PorcentajeUsado%</small>
                                    </td>
                                    <td class="text-center small">
                                        @s.FechaVencimiento.ToString("dd/MM/yyyy")
                                        @if (s.Vencida)
                                        {
                                            <span class="badge bg-danger ms-1">Vencida</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @s.BadgeClass">@s.EstadoVisual</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <a asp-action="Editar" asp-route-id="@s.IdSecuencia"
                                               class="btn btn-sm btn-outline-primary" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            <form asp-action="ToggleActiva" asp-route-id="@s.IdSecuencia" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm @(s.Activa ? "btn-outline-warning" : "btn-outline-success")"
                                                        title="@(s.Activa ? "Desactivar" : "Activar")">
                                                    <i class="bi @(s.Activa ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                                </button>
                                            </form>

                                            @if (s.NumeroActual == s.NumeroInicial)
                                            {
                                                <form asp-action="Eliminar" asp-route-id="@s.IdSecuencia" method="post" class="d-inline"
                                                      onsubmit="return confirm('¿Eliminar esta secuencia NCF?')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Nota informativa -->
    <div class="mt-4 p-3 bg-light rounded border small text-muted">
        <i class="bi bi-info-circle me-1"></i>
        <strong>Tipos de comprobante:</strong>
        B01 – Crédito Fiscal (empresas con RNC) &bull;
        B02 – Consumidor Final (personas físicas) &bull;
        B14 – Régimen Especial &bull;
        B15 – Gubernamental.
        Solo puede haber <strong>una secuencia activa</strong> por tipo a la vez.
    </div>

</div>
