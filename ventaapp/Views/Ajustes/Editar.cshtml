function aplicarAlDOM(c) {
    let style = document.getElementById('ventaapp-theme-v2');
    if (!style) {
        style = document.createElement('style');
        style.id = 'ventaapp-theme-v2';
        document.head.appendChild(style);
    }
    style.textContent = buildCSS(c);
}

/* ===================================================
   GUARDAR / RESETEAR
=================================================== */
function aplicarYGuardar() {
    localStorage.setItem('ventaapp_palette_v2', JSON.stringify(current));
    aplicarAlDOM(current);
    mostrarToast('¡Paleta aplicada en todo el sistema y guardada!');
}

function resetearColores() {
    Object.assign(current, DEFAULT);
    syncAllInputs();
    updatePreview();
    updateCode();
    localStorage.removeItem('ventaapp_palette_v2');
    aplicarAlDOM(current);
    document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
    mostrarToast('Colores restaurados al predeterminado');
}

function copiarCodigo() {
    const ta = document.getElementById('codigoPaleta');
    ta.select();
    document.execCommand('copy');
    mostrarToast('Código copiado al portapapeles 📋');
}

function mostrarToast(msg) {
    const t = document.getElementById('toastMsg');
    document.getElementById('toastText').textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3200);
}
</script>
