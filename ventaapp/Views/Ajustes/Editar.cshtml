@{
    ViewData["Title"] = "Personalización del Sistema";
}

<style>
    /* ── Variables de diseño del editor ──────────────────────────── */
    :root {
        --editor-bg: #f0f4fb;
        --card-bg: #ffffff;
        --text-main: #1a202c;
        --text-muted: #718096;
        --border: #e2e8f0;
        --shadow: 0 4px 24px rgba(79,142,247,.10);
    }

    body { background: var(--editor-bg); }

    .editor-wrapper {
        max-width: 1140px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
    }
    .editor-header { margin-bottom: 2rem; }
    .editor-header h2 {
        font-size: 1.9rem; font-weight: 800;
        color: var(--text-main); letter-spacing: -.5px;
    }
    .editor-header p { color: var(--text-muted); font-size: .95rem; }

    .editor-grid {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 1.5rem;
        align-items: start;
    }
    @@media (max-width: 960px) { .editor-grid { grid-template-columns: 1fr; } }

    .card-panel {
        background: var(--card-bg);
        border-radius: 18px;
        box-shadow: var(--shadow);
        padding: 1.6rem;
        margin-bottom: 1.2rem;
    }
    .panel-title {
        font-size: .72rem; font-weight: 800; letter-spacing: .12em;
        text-transform: uppercase; color: var(--text-muted);
        margin-bottom: 1.2rem;
        display: flex; align-items: center; gap: .5rem;
    }
    .panel-title i { font-size: 1rem; }

    /* Presets */
    .preset-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(125px, 1fr));
        gap: .7rem;
    }
    .preset-card {
        border-radius: 14px; overflow: hidden; cursor: pointer;
        border: 3px solid transparent; transition: all .2s ease; position: relative;
    }
    .preset-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.13); }
    .preset-card.active { border-color: #4f8ef7; box-shadow: 0 0 0 3px rgba(79,142,247,.25); }
    .preset-bar { height: 48px; display: flex; }
    .preset-bar span { flex: 1; }
    .preset-name { font-size: .75rem; font-weight: 700; color: var(--text-main); padding: .45rem .7rem .55rem; background: #f8fafc; display: block; }
    .preset-card.active::after {
        content: '✓'; position: absolute; top: 6px; right: 8px;
        background: #4f8ef7; color: #fff; border-radius: 50%;
        width: 20px; height: 20px; font-size: .7rem; font-weight: 800;
        display: flex; align-items: center; justify-content: center;
    }

    /* Color rows */
    .color-row {
        display: flex; align-items: center; gap: 1rem;
        padding: .7rem 0; border-bottom: 1px solid var(--border);
    }
    .color-row:last-child { border-bottom: none; }
    .color-swatch {
        width: 44px; height: 44px; border-radius: 10px;
        border: none; cursor: pointer; padding: 0; overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.12); flex-shrink: 0; transition: transform .15s;
    }
    .color-swatch:hover { transform: scale(1.1); }
    .color-swatch::-webkit-color-swatch-wrapper { padding: 0; }
    .color-swatch::-webkit-color-swatch { border: none; border-radius: 10px; }
    .color-label { flex: 1; }
    .color-label strong { display: block; font-size: .87rem; font-weight: 700; color: var(--text-main); }
    .color-label small { color: var(--text-muted); font-size: .76rem; }
    .hex-input {
        width: 100px; font-size: .82rem; font-family: 'Courier New', monospace;
        border: 1.5px solid var(--border); border-radius: 8px;
        padding: .35rem .6rem; color: var(--text-main);
        text-transform: uppercase; transition: border-color .2s;
    }
    .hex-input:focus { border-color: #4f8ef7; outline: none; }

    /* Preview navbar */
    .navbar-preview-wrap { border-radius: 14px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,.12); margin-bottom: 1rem; }
    .nav-preview { display: flex; align-items: center; padding: .7rem 1.2rem; gap: 1rem; transition: background .3s; }
    .nav-preview-brand { font-weight: 800; font-size: .95rem; display: flex; align-items: center; gap: .4rem; transition: color .3s; }
    .nav-preview-links { display: flex; gap: .3rem; flex: 1; }
    .nav-preview-link { font-size: .78rem; font-weight: 600; padding: .3rem .7rem; border-radius: 8px; cursor: default; transition: background .2s, color .2s; }
    .nav-preview-user { font-size: .78rem; font-weight: 600; padding: .3rem .7rem; border-radius: 8px; display: flex; align-items: center; gap: .4rem; }

    /* Preview página completa */
    .page-preview-full {
        padding: 1rem 1.2rem;
        background: #f8fafc;
        display: flex;
        flex-direction: column;
        gap: .7rem;
    }
    .prev-row { display: flex; gap: .6rem; align-items: center; }
    .prev-btn { height: 28px; border-radius: 6px; font-size: .72rem; font-weight: 700; display: flex; align-items: center; justify-content: center; padding: 0 .9rem; transition: background .3s, color .3s; }
    .prev-btn-outline { background: transparent; border: 2px solid; }
    .prev-badge { height: 20px; border-radius: 20px; font-size: .65rem; font-weight: 700; display: flex; align-items: center; padding: 0 .7rem; transition: background .3s, color .3s; }
    .prev-card { background: #fff; border-radius: 10px; padding: .7rem 1rem; box-shadow: 0 2px 10px rgba(0,0,0,.07); flex: 1; }
    .prev-card-header { height: 10px; border-radius: 5px; margin-bottom: .5rem; transition: background .3s; }
    .prev-bar { height: 7px; border-radius: 4px; margin-bottom: .35rem; background: #e2e8f0; }
    .prev-bar.accent { background: #4f8ef7; width: 60%; }
    .prev-progress { height: 8px; border-radius: 4px; background: #e2e8f0; overflow: hidden; flex: 1; }
    .prev-progress-fill { height: 100%; border-radius: 4px; width: 65%; transition: background .3s; }
    .prev-link { font-size: .72rem; font-weight: 700; text-decoration: underline; cursor: default; transition: color .3s; }

    /* Botones de acción */
    .btn-apply {
        width: 100%; padding: .85rem; border-radius: 12px; font-weight: 700;
        font-size: .95rem; border: none; cursor: pointer; transition: all .2s;
        display: flex; align-items: center; justify-content: center; gap: .5rem; margin-bottom: .6rem;
    }
    .btn-apply-primary { background: linear-gradient(135deg, #4f8ef7, #764ba2); color: #fff; box-shadow: 0 4px 16px rgba(79,142,247,.35); }
    .btn-apply-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(79,142,247,.45); }
    .btn-apply-reset { background: #f1f5f9; color: #64748b; border: 1.5px solid var(--border); }
    .btn-apply-reset:hover { background: #e2e8f0; }

    /* Slider */
    .slider-wrap { display: flex; align-items: center; gap: .8rem; }
    input[type=range] { flex: 1; -webkit-appearance: none; height: 5px; border-radius: 3px; background: var(--border); outline: none; }
    input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%; background: #4f8ef7; cursor: pointer; border: 3px solid #fff; box-shadow: 0 2px 6px rgba(79,142,247,.4); }

    /* Toast */
    .toast-msg {
        position: fixed; bottom: 2rem; right: 2rem;
        background: #1a202c; color: #fff; padding: .85rem 1.4rem;
        border-radius: 14px; font-size: .88rem; font-weight: 600;
        box-shadow: 0 8px 32px rgba(0,0,0,.25);
        display: flex; align-items: center; gap: .6rem;
        z-index: 9999; transform: translateY(80px); opacity: 0;
        transition: all .35s cubic-bezier(.34,1.56,.64,1); pointer-events: none;
    }
    .toast-msg.show { transform: translateY(0); opacity: 1; }

    /* Tabs de sección de colores */
    .color-tabs { display: flex; gap: .4rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .color-tab {
        font-size: .75rem; font-weight: 700; padding: .35rem .85rem;
        border-radius: 20px; border: 2px solid var(--border);
        background: #f8fafc; color: var(--text-muted); cursor: pointer; transition: all .2s;
    }
    .color-tab.active { background: #4f8ef7; color: #fff; border-color: #4f8ef7; }
    .color-section { display: none; }
    .color-section.active { display: block; }
</style>

<div class="editor-wrapper">

    <div class="editor-header">
        <h2><i class="bi bi-palette2" style="color:#4f8ef7;"></i> Personalización del Sistema</h2>
        <p>Modifica los colores del menú, botones, cards, badges y toda la interfaz. Los cambios se aplican al instante en todo el sistema.</p>
    </div>

    <div class="editor-grid">

        <!-- ── Columna izquierda ───────────────────── -->
        <div>

            <!-- Presets -->
            <div class="card-panel">
                <div class="panel-title"><i class="bi bi-stars"></i> Paletas Predefinidas</div>
                <div class="preset-grid" id="presetGrid"></div>
            </div>

            <!-- Colores por sección -->
            <div class="card-panel">
                <div class="panel-title"><i class="bi bi-sliders"></i> Colores Avanzados</div>

                <div class="color-tabs">
                    <div class="color-tab active" onclick="showTab('tab-nav', this)">🗂 Menú</div>
                    <div class="color-tab" onclick="showTab('tab-btns', this)">🔘 Botones</div>
                    <div class="color-tab" onclick="showTab('tab-ui', this)">🎨 Interfaz</div>
                    <div class="color-tab" onclick="showTab('tab-text', this)">✏️ Tipografía</div>
                </div>

                <!-- TAB: MENÚ -->
                <div class="color-section active" id="tab-nav">
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrNavBg" />
                        <div class="color-label"><strong>Fondo del Menú</strong><small>Color principal del navbar</small></div>
                        <input type="text" class="hex-input" id="hexNavBg" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrNavText" />
                        <div class="color-label"><strong>Texto del Menú</strong><small>Links y íconos del navbar</small></div>
                        <input type="text" class="hex-input" id="hexNavText" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrNavBrand" />
                        <div class="color-label"><strong>Color del Logo</strong><small>Nombre VentaApp</small></div>
                        <input type="text" class="hex-input" id="hexNavBrand" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrDropBg" />
                        <div class="color-label"><strong>Fondo Dropdown</strong><small>Menús desplegables</small></div>
                        <input type="text" class="hex-input" id="hexDropBg" maxlength="7" />
                    </div>
                    <div class="color-row" style="border-bottom:none; padding-bottom:0;">
                        <div style="flex:1;"><strong style="font-size:.87rem;font-weight:700;color:var(--text-main);">Opacidad del fondo</strong><br><small style="color:var(--text-muted);font-size:.76rem;">Efecto glassmorphism</small></div>
                        <div class="slider-wrap" style="width:180px;">
                            <input type="range" id="sliderOpacity" min="70" max="100" value="100" />
                            <span id="opacityVal" style="font-size:.82rem;font-weight:700;color:#4f8ef7;width:36px;">100%</span>
                        </div>
                    </div>
                </div>

                <!-- TAB: BOTONES -->
                <div class="color-section" id="tab-btns">
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrPrimary" />
                        <div class="color-label"><strong>Color Primario</strong><small>btn-primary, encabezados azules</small></div>
                        <input type="text" class="hex-input" id="hexPrimary" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrAccent" />
                        <div class="color-label"><strong>Color Acento</strong><small>Hover, links activos, highlights</small></div>
                        <input type="text" class="hex-input" id="hexAccent" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrSuccess" />
                        <div class="color-label"><strong>Éxito / Verde</strong><small>btn-success, badges verdes</small></div>
                        <input type="text" class="hex-input" id="hexSuccess" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrDanger" />
                        <div class="color-label"><strong>Peligro / Rojo</strong><small>btn-danger, alertas</small></div>
                        <input type="text" class="hex-input" id="hexDanger" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrWarning" />
                        <div class="color-label"><strong>Advertencia / Amarillo</strong><small>btn-warning, estados</small></div>
                        <input type="text" class="hex-input" id="hexWarning" maxlength="7" />
                    </div>
                    <div class="color-row" style="border-bottom:none;">
                        <input type="color" class="color-swatch" id="clrInfo" />
                        <div class="color-label"><strong>Información / Celeste</strong><small>btn-info, badges info</small></div>
                        <input type="text" class="hex-input" id="hexInfo" maxlength="7" />
                    </div>
                </div>

                <!-- TAB: INTERFAZ -->
                <div class="color-section" id="tab-ui">
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrPageBg" />
                        <div class="color-label"><strong>Fondo de Página</strong><small>Color del body / fondo general</small></div>
                        <input type="text" class="hex-input" id="hexPageBg" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrCardBg" />
                        <div class="color-label"><strong>Fondo de Cards</strong><small>Tarjetas y paneles</small></div>
                        <input type="text" class="hex-input" id="hexCardBg" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrTableHead" />
                        <div class="color-label"><strong>Encabezado de Tablas</strong><small>thead de todas las tablas</small></div>
                        <input type="text" class="hex-input" id="hexTableHead" maxlength="7" />
                    </div>
                    <div class="color-row" style="border-bottom:none;">
                        <input type="color" class="color-swatch" id="clrBorder" />
                        <div class="color-label"><strong>Color de Bordes</strong><small>Divisores y bordes de inputs</small></div>
                        <input type="text" class="hex-input" id="hexBorder" maxlength="7" />
                    </div>
                </div>

                <!-- TAB: TIPOGRAFÍA -->
                <div class="color-section" id="tab-text">
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrTextMain" />
                        <div class="color-label"><strong>Texto Principal</strong><small>Títulos y texto general</small></div>
                        <input type="text" class="hex-input" id="hexTextMain" maxlength="7" />
                    </div>
                    <div class="color-row">
                        <input type="color" class="color-swatch" id="clrTextMuted" />
                        <div class="color-label"><strong>Texto Secundario</strong><small>Subtítulos, descripciones</small></div>
                        <input type="text" class="hex-input" id="hexTextMuted" maxlength="7" />
                    </div>
                    <div class="color-row" style="border-bottom:none;">
                        <input type="color" class="color-swatch" id="clrLink" />
                        <div class="color-label"><strong>Color de Links</strong><small>Anchors y enlaces</small></div>
                        <input type="text" class="hex-input" id="hexLink" maxlength="7" />
                    </div>
                </div>

            </div>
        </div>

        <!-- ── Columna derecha ─────────────────────── -->
        <div>

            <!-- Preview completo -->
            <div class="card-panel" style="padding:1.2rem;">
                <div class="panel-title"><i class="bi bi-eye"></i> Vista Previa Completa</div>

                <div class="navbar-preview-wrap">
                    <!-- Navbar preview -->
                    <div class="nav-preview" id="navPreview">
                        <div class="nav-preview-brand" id="prevBrand"><i class="bi bi-shop"></i> VentaApp</div>
                        <div class="nav-preview-links">
                            <div class="nav-preview-link" id="prevLink1">Inicio</div>
                            <div class="nav-preview-link" id="prevLink2">Clientes</div>
                            <div class="nav-preview-link" id="prevLink3">Ventas</div>
                        </div>
                        <div class="nav-preview-user" id="prevUser"><i class="bi bi-person-circle"></i></div>
                    </div>

                    <!-- Page preview -->
                    <div class="page-preview-full" id="pagePreview">
                        <!-- Fila de botones -->
                        <div class="prev-row">
                            <div class="prev-btn" id="prevBtnPrimary">Guardar</div>
                            <div class="prev-btn" id="prevBtnSuccess">Nuevo</div>
                            <div class="prev-btn" id="prevBtnDanger">Eliminar</div>
                            <div class="prev-btn" id="prevBtnWarning">Editar</div>
                        </div>
                        <!-- Fila de badges -->
                        <div class="prev-row">
                            <div class="prev-badge" id="prevBadgePrimary">Activo</div>
                            <div class="prev-badge" id="prevBadgeSuccess">Completada</div>
                            <div class="prev-badge" id="prevBadgeDanger">Anulada</div>
                            <div class="prev-badge" id="prevBadgeInfo">Información</div>
                            <div class="prev-link" id="prevLink">ver detalles →</div>
                        </div>
                        <!-- Cards mini -->
                        <div class="prev-row" style="align-items:stretch;">
                            <div class="prev-card" style="flex:1;">
                                <div class="prev-card-header" id="prevCardH1"></div>
                                <div class="prev-bar" style="width:80%;"></div>
                                <div class="prev-bar" style="width:55%;"></div>
                            </div>
                            <div class="prev-card" style="flex:1;">
                                <div class="prev-card-header" id="prevCardH2"></div>
                                <div class="prev-bar" style="width:70%;"></div>
                                <div class="prev-bar" style="width:40%;"></div>
                            </div>
                        </div>
                        <!-- Progress + tabla mini -->
                        <div class="prev-row">
                            <div style="flex:1; font-size:.7rem; font-weight:600;" id="prevTableLabel">Ventas</div>
                            <div class="prev-progress" style="flex:3;">
                                <div class="prev-progress-fill" id="prevProgressFill"></div>
                            </div>
                            <div style="font-size:.7rem; font-weight:700;" id="prevTableValue">65%</div>
                        </div>
                    </div>
                </div>

                <small style="color:var(--text-muted);font-size:.74rem;display:block;text-align:center;margin-top:.3rem;">
                    <i class="bi bi-info-circle"></i> Previsualización de toda la interfaz
                </small>
            </div>

            <!-- Acciones -->
            <div class="card-panel" style="padding:1.2rem;">
                <div class="panel-title"><i class="bi bi-floppy2"></i> Guardar Cambios</div>
                <button class="btn-apply btn-apply-primary" onclick="aplicarYGuardar()">
                    <i class="bi bi-check2-circle"></i> Aplicar y Guardar en Todo el Sistema
                </button>
                <button class="btn-apply btn-apply-reset" onclick="resetearColores()">
                    <i class="bi bi-arrow-counterclockwise"></i> Restaurar Predeterminado
                </button>
                <div style="margin-top:1rem;padding:.9rem;background:#f8fafc;border-radius:10px;border:1px solid var(--border);">
                    <small style="color:var(--text-muted);font-size:.76rem;line-height:1.6;">
                        <i class="bi bi-shield-check" style="color:#4f8ef7;"></i>
                        Los cambios se aplican automáticamente en <strong>todas las páginas</strong> del sistema: menú, botones, cards, tablas, badges, modales y más.
                    </small>
                </div>
            </div>

            <!-- Código exportable -->
            <div class="card-panel" style="padding:1.2rem;">
                <div class="panel-title"><i class="bi bi-code-square"></i> Código de Paleta</div>
                <textarea id="codigoPaleta" readonly style="width:100%;height:90px;font-family:'Courier New',monospace;font-size:.72rem;border:1.5px solid var(--border);border-radius:10px;padding:.6rem;color:var(--text-main);background:#f8fafc;resize:none;outline:none;line-height:1.7;"></textarea>
                <button onclick="copiarCodigo()" style="margin-top:.5rem;width:100%;padding:.5rem;border-radius:8px;border:1.5px solid var(--border);background:#f1f5f9;font-size:.8rem;font-weight:600;cursor:pointer;color:var(--text-muted);">
                    <i class="bi bi-clipboard"></i> Copiar código de paleta
                </button>
            </div>

        </div>
    </div>
</div>

<div class="toast-msg" id="toastMsg">
    <i class="bi bi-check-circle-fill" style="color:#4ade80;"></i>
    <span id="toastText">¡Cambios aplicados!</span>
</div>

@section Scripts {
<script>
/* ===================================================
   PALETAS PREDEFINIDAS (incluyen TODOS los colores)
=================================================== */
const PRESETS = [
    {
        name:'Océano Profundo', navBg:'#0a1628', navText:'#e8f4fd', navBrand:'#60c3ff', dropBg:'#0d1f3c',
        primary:'#3b9ded', accent:'#60c3ff', success:'#10b981', danger:'#ef4444', warning:'#f59e0b', info:'#06b6d4',
        pageBg:'#f0f7ff', cardBg:'#ffffff', tableHead:'#0a1628', border:'#bfdbfe',
        textMain:'#0f172a', textMuted:'#475569', link:'#3b9ded', opacity:100
    },
    {
        name:'Medianoche', navBg:'#1a1a2e', navText:'#e0e0ff', navBrand:'#a78bfa', dropBg:'#16213e',
        primary:'#7c3aed', accent:'#a78bfa', success:'#059669', danger:'#dc2626', warning:'#d97706', info:'#0891b2',
        pageBg:'#f5f3ff', cardBg:'#ffffff', tableHead:'#1a1a2e', border:'#ddd6fe',
        textMain:'#1e1b4b', textMuted:'#6d28d9', link:'#7c3aed', opacity:100
    },
    {
        name:'Bosque Verde', navBg:'#1b2e1f', navText:'#d4edda', navBrand:'#86efac', dropBg:'#1e3a22',
        primary:'#16a34a', accent:'#22c55e', success:'#15803d', danger:'#dc2626', warning:'#ca8a04', info:'#0284c7',
        pageBg:'#f0fdf4', cardBg:'#ffffff', tableHead:'#1b2e1f', border:'#bbf7d0',
        textMain:'#14532d', textMuted:'#166534', link:'#16a34a', opacity:100
    },
    {
        name:'Carbón', navBg:'#18181b', navText:'#f4f4f5', navBrand:'#fdba74', dropBg:'#27272a',
        primary:'#f97316', accent:'#fb923c', success:'#22c55e', danger:'#ef4444', warning:'#eab308', info:'#06b6d4',
        pageBg:'#fafafa', cardBg:'#ffffff', tableHead:'#18181b', border:'#e4e4e7',
        textMain:'#09090b', textMuted:'#71717a', link:'#f97316', opacity:100
    },
