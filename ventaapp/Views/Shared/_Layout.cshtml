<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VentaApp</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ventaapp.styles.css" asp-append-version="true" />
    
    <!-- ===== FRAGMENTO PARA _Layout.cshtml =====
     Pegar dentro del <head>, antes del </head>.
     Aplica la paleta de colores y modo oscuro en TODAS las páginas.
     =========================================== -->

<script>
(function () {

    /* ── 1. Modo oscuro: aplicar clase ANTES de renderizar ── */
    var darkMode = localStorage.getItem('ventaapp_dark_mode') === 'true';
    if (darkMode) document.documentElement.classList.add('va-dark');

    /* ── 2. Leer paletas ── */
    var saved    = localStorage.getItem('ventaapp_palette_v2');
    var savedDk  = localStorage.getItem('ventaapp_dark_palette');
    if (!saved && !darkMode) return;

    try {
        var c  = saved   ? JSON.parse(saved)  : {};
        var dk = savedDk ? JSON.parse(savedDk) : {};

        /* Defaults paleta clara */
        var navBg    = c.navBg    || '#212529';
        var navText  = c.navText  || '#ffffff';
        var navBrand = c.navBrand || '#ffffff';
        var dropBg   = c.dropBg   || '#ffffff';
        var primary  = c.primary  || '#0d6efd';
        var accent   = c.accent   || '#0d6efd';
        var success  = c.success  || '#198754';
        var danger   = c.danger   || '#dc3545';
        var warning  = c.warning  || '#ffc107';
        var info     = c.info     || '#0dcaf0';
        var pageBg   = c.pageBg   || '#f8f9fa';
        var cardBg   = c.cardBg   || '#ffffff';
        var tableH   = c.tableHead|| '#212529';
        var border   = c.border   || '#dee2e6';
        var textMain = c.textMain || '#212529';
        var textMut  = c.textMuted|| '#6c757d';
        var link     = c.link     || '#0d6efd';
        var op       = ((c.opacity || 100) / 100).toFixed(2);

        /* Defaults paleta oscura */
        var dkBg   = dk.dkBody    || '#0f1117';
        var dkCard = dk.dkCard    || '#1a1d27';
        var dkSurf = dk.dkSurface || '#252836';
        var dkInp  = dk.dkInput   || '#252836';
        var dkBrd  = dk.dkBorder  || '#2d3147';
        var dkTxt  = dk.dkText    || '#e2e8f0';
        var dkMut  = dk.dkMuted   || '#64748b';

        /* ── Helpers ── */
        function rgb(hex) {
            if (!hex || hex.length < 7) return '0,0,0';
            return parseInt(hex.slice(1,3),16)+','+parseInt(hex.slice(3,5),16)+','+parseInt(hex.slice(5,7),16);
        }
        function isLight(hex) {
            if (!hex || hex.length < 7) return true;
            var r = parseInt(hex.slice(1,3),16);
            var g = parseInt(hex.slice(3,5),16);
            var b = parseInt(hex.slice(5,7),16);
            return (r*299 + g*587 + b*114) / 1000 > 128;
        }

        /* Texto del dropdown con contraste garantizado sobre dropBg */
        var dropTxt;
        if (isLight(dropBg)) {
            dropTxt = isLight(navText) ? '#1a202c' : navText;
        } else {
            dropTxt = !isLight(navText) ? '#f8f9fa' : navText;
        }

        /* ── 3. Construir CSS ── */
        var css = '';

        /* Variables globales */
        css += ':root{';
        css += '--va-primary:'+primary+';';
        css += '--va-accent:'+accent+';';
        css += '--va-success:'+success+';';
        css += '--va-danger:'+danger+';';
        css += '--va-warning:'+warning+';';
        css += '--va-info:'+info+';';
        css += '--va-page-bg:'+pageBg+';';
        css += '--va-card-bg:'+cardBg+';';
        css += '--va-table-head:'+tableH+';';
        css += '--va-border:'+border+';';
        css += '--va-text:'+textMain+';';
        css += '--va-muted:'+textMut+';';
        css += '--va-link:'+link+';';
        css += '}';

        /* Body */
        css += 'body{background-color:'+pageBg+' !important;color:'+textMain+' !important;}';

        /* Navbar */
        css += '.navbar[data-bs-theme]{background:rgba('+rgb(navBg)+','+op+') !important;backdrop-filter:'+(op<1?'blur(14px)':'none')+' !important;}';
        css += '.navbar .navbar-brand,.navbar .navbar-brand i{color:'+navBrand+' !important;}';
        css += '.navbar .nav-link,.navbar .navbar-nav .nav-link{color:'+navText+' !important;}';
        css += '.navbar .nav-link:hover,.navbar .nav-link:focus{color:'+accent+' !important;background:'+accent+'22 !important;border-radius:8px !important;}';
        css += '.navbar .dropdown-menu{background:'+dropBg+' !important;border-color:'+accent+'33 !important;border-radius:14px !important;box-shadow:0 8px 32px rgba(0,0,0,.18) !important;}';
        css += '.navbar .dropdown-item{color:'+dropTxt+' !important;}';
        css += '.navbar .dropdown-item:hover{background:'+accent+' !important;color:#fff !important;border-radius:8px !important;}';
        css += '.navbar .dropdown-header strong{color:'+accent+' !important;}';
        css += '.navbar .dropdown-divider{border-color:'+dropTxt+'22 !important;}';
        css += '.navbar .form-control{background:'+dropBg+' !important;color:'+dropTxt+' !important;border-color:'+dropTxt+'33 !important;}';
        css += '.navbar .form-control::placeholder{color:'+dropTxt+'77 !important;}';
        css += '.navbar .btn-outline-success{color:'+accent+' !important;border-color:'+accent+' !important;}';
        css += '.navbar .btn-outline-success:hover{background:'+accent+' !important;color:#fff !important;}';

        /* Botones */
        css += '.btn-primary{background-color:'+primary+' !important;border-color:'+primary+' !important;color:#fff !important;}';
        css += '.btn-primary:hover{background-color:'+primary+'dd !important;border-color:'+primary+'dd !important;}';
        css += '.btn-outline-primary{color:'+primary+' !important;border-color:'+primary+' !important;}';
        css += '.btn-outline-primary:hover{background-color:'+primary+' !important;color:#fff !important;}';
        css += '.btn-success{background-color:'+success+' !important;border-color:'+success+' !important;color:#fff !important;}';
        css += '.btn-success:hover{background-color:'+success+'dd !important;}';
        css += '.btn-outline-success:not(.navbar .btn-outline-success){color:'+success+' !important;border-color:'+success+' !important;}';
        css += '.btn-outline-success:not(.navbar .btn-outline-success):hover{background-color:'+success+' !important;color:#fff !important;}';
        css += '.btn-danger{background-color:'+danger+' !important;border-color:'+danger+' !important;color:#fff !important;}';
        css += '.btn-danger:hover{background-color:'+danger+'dd !important;}';
        css += '.btn-outline-danger{color:'+danger+' !important;border-color:'+danger+' !important;}';
        css += '.btn-outline-danger:hover{background-color:'+danger+' !important;color:#fff !important;}';
        css += '.btn-warning{background-color:'+warning+' !important;border-color:'+warning+' !important;}';
        css += '.btn-warning:hover{background-color:'+warning+'dd !important;}';
        css += '.btn-outline-warning{color:'+warning+' !important;border-color:'+warning+' !important;}';
        css += '.btn-outline-warning:hover{background-color:'+warning+' !important;}';
        css += '.btn-info{background-color:'+info+' !important;border-color:'+info+' !important;color:#fff !important;}';
        css += '.btn-info:hover{background-color:'+info+'dd !important;}';
        css += '.btn-outline-info{color:'+info+' !important;border-color:'+info+' !important;}';
        css += '.btn-outline-info:hover{background-color:'+info+' !important;color:#fff !important;}';

        /* Cards */
        css += '.card{background:'+cardBg+' !important;border-color:'+border+' !important;}';
        css += '.card-header.bg-primary{background-color:'+primary+' !important;}';
        css += '.card-header.bg-success{background-color:'+success+' !important;}';
        css += '.card-header.bg-danger{background-color:'+danger+' !important;}';
        css += '.card-header.bg-warning{background-color:'+warning+' !important;}';
        css += '.card-header.bg-info{background-color:'+info+' !important;}';
        css += '.card-header.bg-dark{background-color:'+tableH+' !important;}';
        css += '.card-header.bg-secondary{background-color:'+textMut+' !important;}';

        /* Badges */
        css += '.badge.bg-primary{background-color:'+primary+' !important;}';
        css += '.badge.bg-success{background-color:'+success+' !important;}';
        css += '.badge.bg-danger{background-color:'+danger+' !important;}';
        css += '.badge.bg-warning{background-color:'+warning+' !important;color:#000 !important;}';
        css += '.badge.bg-info{background-color:'+info+' !important;color:#fff !important;}';
        css += '.badge.bg-dark{background-color:'+tableH+' !important;}';
        css += '.badge.bg-secondary{background-color:'+textMut+' !important;}';

        /* Tablas */
        css += '.table-dark,thead.table-dark tr,.table thead.table-dark th{background-color:'+tableH+' !important;color:#fff !important;}';
        css += '.table-hover tbody tr:hover{background-color:'+primary+'11 !important;}';
        css += '.table-striped tbody tr:nth-of-type(odd){background-color:'+primary+'08 !important;}';
        css += '.table-primary{background-color:'+primary+'22 !important;}';
        css += '.table-success{background-color:'+success+'22 !important;}';
        css += '.table-danger{background-color:'+danger+'22 !important;}';
        css += '.table-warning{background-color:'+warning+'22 !important;}';

        /* Alertas */
        css += '.alert-success{background-color:'+success+'22 !important;border-color:'+success+'66 !important;color:'+success+' !important;}';
        css += '.alert-danger{background-color:'+danger+'22 !important;border-color:'+danger+'66 !important;color:'+danger+' !important;}';
        css += '.alert-warning{background-color:'+warning+'22 !important;border-color:'+warning+'66 !important;color:'+warning+'cc !important;}';
        css += '.alert-info{background-color:'+info+'22 !important;border-color:'+info+'66 !important;color:'+info+' !important;}';
        css += '.alert-primary{background-color:'+primary+'22 !important;border-color:'+primary+'66 !important;color:'+primary+' !important;}';

        /* Formularios */
        css += '.form-control:focus,.form-select:focus{border-color:'+accent+' !important;box-shadow:0 0 0 .2rem '+accent+'33 !important;}';
        css += '.form-check-input:checked{background-color:'+primary+' !important;border-color:'+primary+' !important;}';

        /* Progress */
        css += '.progress-bar{background-color:'+primary+' !important;}';
        css += '.progress-bar.bg-success{background-color:'+success+' !important;}';
        css += '.progress-bar.bg-danger{background-color:'+danger+' !important;}';
        css += '.progress-bar.bg-warning{background-color:'+warning+' !important;}';
        css += '.progress-bar.bg-info{background-color:'+info+' !important;}';

        /* Modales */
        css += '.modal-header.bg-primary{background-color:'+primary+' !important;}';
        css += '.modal-header.bg-danger{background-color:'+danger+' !important;}';
        css += '.modal-header.bg-success{background-color:'+success+' !important;}';
        css += '.modal-header.bg-warning{background-color:'+warning+' !important;}';
        css += '.modal-content{background:'+cardBg+' !important;border-color:'+border+' !important;}';

        /* Paginación */
        css += '.page-link{color:'+primary+' !important;}';
        css += '.page-item.active .page-link{background-color:'+primary+' !important;border-color:'+primary+' !important;color:#fff !important;}';

        /* Links */
        css += 'a:not(.btn):not(.nav-link):not(.navbar-brand):not(.dropdown-item){color:'+link+' !important;}';
        css += 'a:not(.btn):not(.nav-link):not(.navbar-brand):not(.dropdown-item):hover{color:'+accent+' !important;}';

        /* Textos */
        css += '.text-primary{color:'+primary+' !important;}';
        css += '.text-success{color:'+success+' !important;}';
        css += '.text-danger{color:'+danger+' !important;}';
        css += '.text-warning{color:'+warning+' !important;}';
        css += '.text-info{color:'+info+' !important;}';
        css += '.text-muted{color:'+textMut+' !important;}';

        /* Backgrounds */
        css += '.bg-primary{background-color:'+primary+' !important;}';
        css += '.bg-success{background-color:'+success+' !important;}';
        css += '.bg-danger{background-color:'+danger+' !important;}';
        css += '.bg-warning{background-color:'+warning+' !important;}';
        css += '.bg-info{background-color:'+info+' !important;}';
        css += '.bg-light{background-color:'+cardBg+' !important;}';

        /* Bordes */
        css += '.border-primary{border-color:'+primary+' !important;}';
        css += '.border-success{border-color:'+success+' !important;}';
        css += '.border-danger{border-color:'+danger+' !important;}';
        css += '.border-warning{border-color:'+warning+' !important;}';
        css += '.border-info{border-color:'+info+' !important;}';
        css += '.border-top,.border-bottom,.border{border-color:'+border+' !important;}';

        /* List groups */
        css += '.list-group-item-action:hover{background:'+primary+'11 !important;}';
        css += '.list-group-item.active{background-color:'+primary+' !important;border-color:'+primary+' !important;}';

        /* Input group */
        css += '.input-group-text{background-color:'+pageBg+' !important;border-color:'+border+' !important;color:'+textMut+' !important;}';

        /* Footer */
        css += 'footer.footer{border-color:'+border+' !important;color:'+textMut+' !important;}';
        css += 'footer.footer a{color:'+link+' !important;}';

        /* ── 4. CSS Modo Oscuro ── */
        if (darkMode) {
            css += '.va-dark body{background-color:'+dkBg+' !important;color:'+dkTxt+' !important;}';

            /* Cards */
            css += '.va-dark .card,.va-dark .card-panel-inner{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .card-body,.va-dark .card-footer{color:'+dkTxt+' !important;}';
            css += '.va-dark .card-header{background:'+dkSurf+' !important;border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .card-header.bg-primary{background-color:'+primary+' !important;color:#fff !important;}';
            css += '.va-dark .card-header.bg-success{background-color:'+success+' !important;color:#fff !important;}';
            css += '.va-dark .card-header.bg-danger{background-color:'+danger+' !important;color:#fff !important;}';
            css += '.va-dark .card-header.bg-warning{background-color:'+warning+' !important;}';
            css += '.va-dark .card-header.bg-info{background-color:'+info+' !important;color:#fff !important;}';
            css += '.va-dark .card-header.bg-dark{background-color:'+dkSurf+' !important;color:'+dkTxt+' !important;}';

            /* Modales */
            css += '.va-dark .modal-content{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .modal-header{background:'+dkSurf+' !important;border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .modal-footer{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;}';
            css += '.va-dark .modal-header.bg-primary{background-color:'+primary+' !important;color:#fff !important;}';
            css += '.va-dark .modal-header.bg-danger{background-color:'+danger+' !important;color:#fff !important;}';
            css += '.va-dark .modal-header.bg-success{background-color:'+success+' !important;color:#fff !important;}';

            /* Formularios */
            css += '.va-dark .form-control,.va-dark .form-select{background-color:'+dkInp+' !important;border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .form-control::placeholder{color:'+dkMut+' !important;}';
            css += '.va-dark .form-control:focus,.va-dark .form-select:focus{background-color:'+dkInp+' !important;border-color:'+accent+' !important;box-shadow:0 0 0 .2rem '+accent+'33 !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .form-label,.va-dark label{color:'+dkTxt+'cc !important;}';
            css += '.va-dark .input-group-text{background:'+dkSurf+' !important;border-color:'+dkBrd+' !important;color:'+dkMut+' !important;}';
            css += '.va-dark select option{background:'+dkInp+';color:'+dkTxt+';}';

            /* Tablas — cobertura total: ninguna celda queda blanca */
            css += '.va-dark .table{color:'+dkTxt+' !important;background-color:'+dkCard+' !important;}';
            css += '.va-dark .table>:not(caption)>*>*{background-color:'+dkCard+' !important;color:'+dkTxt+' !important;border-bottom-color:'+dkBrd+' !important;}';
            css += '.va-dark .table tbody,.va-dark .table tbody tr,.va-dark .table tbody td,.va-dark .table tbody th{background-color:'+dkCard+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table td,.va-dark .table th{border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table thead th,.va-dark .table thead tr{background:'+dkSurf+' !important;color:'+dkTxt+' !important;border-color:'+dkBrd+' !important;}';
            css += '.va-dark .table .bg-white,.va-dark .table .bg-light{background-color:'+dkCard+' !important;}';
            css += '.va-dark .table-dark,.va-dark thead.table-dark tr,.va-dark .table thead.table-dark th{background-color:'+dkSurf+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table-striped>tbody>tr:nth-of-type(odd)>*{background-color:'+dkSurf+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table-hover>tbody>tr:hover>*{background-color:'+accent+'22 !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table-hover>tbody>tr:hover td,.va-dark .table-hover>tbody>tr:hover th{color:'+dkTxt+' !important;}';
            css += '.va-dark .table-bordered,.va-dark .table-bordered td,.va-dark .table-bordered th{border-color:'+dkBrd+' !important;}';
            css += '.va-dark .table-primary>*{background-color:'+primary+'33 !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table-success>*{background-color:'+success+'33 !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table-danger>*{background-color:'+danger+'33 !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .table-warning>*{background-color:'+warning+'33 !important;color:'+dkTxt+' !important;}';

            /* Dropdowns */
            css += '.va-dark .dropdown-menu{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;}';
            css += '.va-dark .dropdown-item{color:'+dkTxt+'cc !important;}';
            css += '.va-dark .dropdown-item:hover{background:'+dkSurf+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .dropdown-divider{border-color:'+dkBrd+' !important;}';
            css += '.va-dark .dropdown-header{color:'+dkMut+' !important;}';

            /* Alertas */
            css += '.va-dark .alert-success{background-color:'+success+'18 !important;border-color:'+success+'44 !important;color:'+success+' !important;}';
            css += '.va-dark .alert-danger{background-color:'+danger+'18 !important;border-color:'+danger+'44 !important;color:'+danger+' !important;}';
            css += '.va-dark .alert-warning{background-color:'+warning+'18 !important;border-color:'+warning+'44 !important;color:'+warning+' !important;}';
            css += '.va-dark .alert-info{background-color:'+info+'18 !important;border-color:'+info+'44 !important;color:'+info+' !important;}';
            css += '.va-dark .alert-primary{background-color:'+primary+'18 !important;border-color:'+primary+'44 !important;color:'+primary+' !important;}';
            css += '.va-dark .alert-dark,.va-dark .alert-secondary{background-color:'+dkSurf+' !important;border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';

            /* List groups */
            css += '.va-dark .list-group-item{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .list-group-item-action:hover{background:'+dkSurf+' !important;}';
            css += '.va-dark .list-group-item.active{background-color:'+primary+' !important;border-color:'+primary+' !important;color:#fff !important;}';

            /* Nav tabs */
            css += '.va-dark .nav-tabs{border-color:'+dkBrd+' !important;}';
            css += '.va-dark .nav-tabs .nav-link{color:'+dkMut+' !important;}';
            css += '.va-dark .nav-tabs .nav-link:hover{color:'+dkTxt+' !important;border-color:'+dkBrd+' !important;}';
            css += '.va-dark .nav-tabs .nav-link.active{background:'+dkCard+' !important;border-color:'+dkBrd+' '+dkBrd+' '+dkCard+' !important;color:'+accent+' !important;}';

            /* Paginación */
            css += '.va-dark .page-link{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;color:'+primary+' !important;}';
            css += '.va-dark .page-link:hover{background:'+dkSurf+' !important;}';
            css += '.va-dark .page-item.active .page-link{background-color:'+primary+' !important;border-color:'+primary+' !important;color:#fff !important;}';
            css += '.va-dark .page-item.disabled .page-link{background:'+dkBg+' !important;border-color:'+dkBrd+' !important;color:'+dkMut+' !important;}';

            /* Textos */
            css += '.va-dark .text-dark,.va-dark .text-body{color:'+dkTxt+' !important;}';
            css += '.va-dark .text-muted{color:'+dkMut+' !important;}';
            css += '.va-dark small,.va-dark .small{color:'+dkMut+' !important;}';
            css += '.va-dark h1,.va-dark h2,.va-dark h3,.va-dark h4,.va-dark h5,.va-dark h6{color:'+dkTxt+' !important;}';

            /* Bordes */
            css += '.va-dark .border,.va-dark .border-top,.va-dark .border-bottom,.va-dark .border-start,.va-dark .border-end{border-color:'+dkBrd+' !important;}';
            css += '.va-dark hr{border-color:'+dkBrd+' !important;}';

            /* Backgrounds */
            css += '.va-dark .bg-light{background-color:'+dkSurf+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .bg-white{background-color:'+dkCard+' !important;}';
            css += '.va-dark .bg-body,.va-dark .bg-body-secondary{background-color:'+dkBg+' !important;}';
            css += '.va-dark .bg-dark{background-color:'+dkBg+' !important;}';

            /* Accordion */
            css += '.va-dark .accordion-item{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;}';
            css += '.va-dark .accordion-button{background:'+dkSurf+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .accordion-button:not(.collapsed){background:'+dkBrd+' !important;color:'+accent+' !important;}';
            css += '.va-dark .accordion-button::after{filter:invert(1);}';
            css += '.va-dark .accordion-body{background:'+dkCard+' !important;color:'+dkTxt+' !important;}';

            /* Offcanvas & popovers */
            css += '.va-dark .offcanvas{background:'+dkCard+' !important;color:'+dkTxt+' !important;}';
            css += '.va-dark .offcanvas-header{border-color:'+dkBrd+' !important;}';
            css += '.va-dark .popover{background:'+dkCard+' !important;border-color:'+dkBrd+' !important;}';
            css += '.va-dark .popover-header{background:'+dkSurf+' !important;color:'+dkTxt+' !important;border-color:'+dkBrd+' !important;}';
            css += '.va-dark .popover-body{color:'+dkTxt+'cc !important;}';

            /* Footer & progress */
            css += '.va-dark footer.footer{background:'+dkBg+' !important;border-color:'+dkBrd+' !important;color:'+dkMut+' !important;}';
            css += '.va-dark .progress{background:'+dkSurf+' !important;}';

            /* Breadcrumb */
            css += '.va-dark .breadcrumb-item,.va-dark .breadcrumb-item a{color:'+dkMut+' !important;}';
            css += '.va-dark .breadcrumb-item.active{color:'+dkTxt+' !important;}';
            css += '.va-dark .breadcrumb-item+.breadcrumb-item::before{color:'+dkMut+' !important;}';

            /* Scrollbar */
            css += '.va-dark ::-webkit-scrollbar-track{background:'+dkCard+' !important;}';
            css += '.va-dark ::-webkit-scrollbar-thumb{background:'+dkBrd+' !important;border-radius:4px !important;}';
            css += '.va-dark ::-webkit-scrollbar-thumb:hover{background:'+accent+' !important;}';
        }

        /* ── 5. Inyectar — reusar tag si ya existe ── */
        var el = document.getElementById('ventaapp-theme-v2');
        if (!el) {
            el = document.createElement('style');
            el.id = 'ventaapp-theme-v2';
            document.head.appendChild(el);
        }
        el.textContent = css;

    } catch(e) { console.warn('VentaApp theme error:', e); }
})();
</script>

<!-- FIN DEL FRAGMENTO -->
