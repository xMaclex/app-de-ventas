<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VentaApp</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ventaapp.styles.css" asp-append-version="true" />
    <script>
(function () {
    var saved = localStorage.getItem('ventaapp_palette_v2');
    if (!saved) return;
    try {
        var c = JSON.parse(saved);
        var op = (c.opacity || 100) / 100;

        function rgb(hex) {
            if (!hex || hex.length < 7) return '0,0,0';
            return parseInt(hex.slice(1,3),16)+','+parseInt(hex.slice(3,5),16)+','+parseInt(hex.slice(5,7),16);
        }

        var css = [
            /* ── Variables CSS globales ── */
            ':root{',
            '--va-primary:'+c.primary+';',
            '--va-accent:'+c.accent+';',
            '--va-success:'+c.success+';',
            '--va-danger:'+c.danger+';',
            '--va-warning:'+c.warning+';',
            '--va-info:'+c.info+';',
            '--va-page-bg:'+c.pageBg+';',
            '--va-card-bg:'+c.cardBg+';',
            '--va-table-head:'+c.tableHead+';',
            '--va-border:'+c.border+';',
            '--va-text:'+c.textMain+';',
            '--va-muted:'+c.textMuted+';',
            '--va-link:'+c.link+';',
            '}',

            /* ── BODY ── */
            'body{background-color:'+c.pageBg+' !important;color:'+c.textMain+' !important;}',

            /* ── NAVBAR ── */
            '.navbar[data-bs-theme]{background:rgba('+rgb(c.navBg)+','+op+') !important;backdrop-filter:'+(op<1?'blur(14px)':'none')+' !important;}',
            '.navbar .navbar-brand,.navbar .navbar-brand i{color:'+c.navBrand+' !important;}',
            '.navbar .nav-link,.navbar .navbar-nav .nav-link{color:'+c.navText+' !important;}',
            '.navbar .nav-link:hover,.navbar .nav-link:focus{color:'+c.accent+' !important;background:'+c.accent+'22 !important;border-radius:8px !important;}',
            '.navbar .dropdown-menu{background:'+c.dropBg+' !important;border-color:'+c.accent+'33 !important;border-radius:14px !important;box-shadow:0 8px 32px rgba(0,0,0,.18) !important;}',
            '.navbar .dropdown-item{color:'+c.navText+' !important;}',
            '.navbar .dropdown-item:hover{background:'+c.accent+'22 !important;color:'+c.accent+' !important;border-radius:8px !important;}',
            '.navbar .dropdown-header strong{color:'+c.navBrand+' !important;}',
            '.navbar .dropdown-divider{border-color:'+c.navText+'22 !important;}',
            '.navbar .form-control{background:'+c.dropBg+' !important;color:'+c.navText+' !important;border-color:'+c.navText+'33 !important;}',
            '.navbar .form-control::placeholder{color:'+c.navText+'77 !important;}',
            '.navbar .btn-outline-success{color:'+c.accent+' !important;border-color:'+c.accent+' !important;}',
            '.navbar .btn-outline-success:hover{background:'+c.accent+' !important;color:#fff !important;}',

            /* ── BOTONES ── */
            '.btn-primary{background-color:'+c.primary+' !important;border-color:'+c.primary+' !important;color:#fff !important;}',
            '.btn-primary:hover{background-color:'+c.primary+'dd !important;border-color:'+c.primary+'dd !important;}',
            '.btn-outline-primary{color:'+c.primary+' !important;border-color:'+c.primary+' !important;}',
            '.btn-outline-primary:hover{background-color:'+c.primary+' !important;color:#fff !important;}',

            '.btn-success{background-color:'+c.success+' !important;border-color:'+c.success+' !important;color:#fff !important;}',
            '.btn-success:hover{background-color:'+c.success+'dd !important;}',
            '.btn-outline-success:not(.navbar .btn-outline-success){color:'+c.success+' !important;border-color:'+c.success+' !important;}',
            '.btn-outline-success:not(.navbar .btn-outline-success):hover{background-color:'+c.success+' !important;color:#fff !important;}',

            '.btn-danger{background-color:'+c.danger+' !important;border-color:'+c.danger+' !important;color:#fff !important;}',
            '.btn-danger:hover{background-color:'+c.danger+'dd !important;}',
            '.btn-outline-danger{color:'+c.danger+' !important;border-color:'+c.danger+' !important;}',
            '.btn-outline-danger:hover{background-color:'+c.danger+' !important;color:#fff !important;}',

            '.btn-warning{background-color:'+c.warning+' !important;border-color:'+c.warning+' !important;}',
            '.btn-warning:hover{background-color:'+c.warning+'dd !important;}',
            '.btn-outline-warning{color:'+c.warning+' !important;border-color:'+c.warning+' !important;}',
            '.btn-outline-warning:hover{background-color:'+c.warning+' !important;}',

            '.btn-info{background-color:'+c.info+' !important;border-color:'+c.info+' !important;color:#fff !important;}',
            '.btn-info:hover{background-color:'+c.info+'dd !important;}',
            '.btn-outline-info{color:'+c.info+' !important;border-color:'+c.info+' !important;}',
            '.btn-outline-info:hover{background-color:'+c.info+' !important;color:#fff !important;}',

            /* ── CARDS ── */
            '.card{background:'+c.cardBg+' !important;border-color:'+c.border+' !important;}',
            '.card-header.bg-primary{background-color:'+c.primary+' !important;}',
            '.card-header.bg-success{background-color:'+c.success+' !important;}',
            '.card-header.bg-danger{background-color:'+c.danger+' !important;}',
            '.card-header.bg-warning{background-color:'+c.warning+' !important;}',
            '.card-header.bg-info{background-color:'+c.info+' !important;}',
            '.card-header.bg-dark{background-color:'+c.tableHead+' !important;}',
            '.card-header.bg-secondary{background-color:'+c.textMuted+' !important;}',

            /* ── BADGES ── */
            '.badge.bg-primary{background-color:'+c.primary+' !important;}',
            '.badge.bg-success{background-color:'+c.success+' !important;}',
            '.badge.bg-danger{background-color:'+c.danger+' !important;}',
            '.badge.bg-warning{background-color:'+c.warning+' !important;color:#000 !important;}',
            '.badge.bg-info{background-color:'+c.info+' !important;color:#fff !important;}',
            '.badge.bg-dark{background-color:'+c.tableHead+' !important;}',
            '.badge.bg-secondary{background-color:'+c.textMuted+' !important;}',

            /* ── TABLAS ── */
            '.table-dark,thead.table-dark tr,.table thead.table-dark th{background-color:'+c.tableHead+' !important;color:#fff !important;}',
            '.table-hover tbody tr:hover{background-color:'+c.primary+'11 !important;}',
            '.table-striped tbody tr:nth-of-type(odd){background-color:'+c.primary+'08 !important;}',
            '.table-primary{background-color:'+c.primary+'22 !important;}',
            '.table-success{background-color:'+c.success+'22 !important;}',
            '.table-danger{background-color:'+c.danger+'22 !important;}',
            '.table-warning{background-color:'+c.warning+'22 !important;}',

            /* ── ALERTAS ── */
            '.alert-success{background-color:'+c.success+'22 !important;border-color:'+c.success+'66 !important;color:'+c.success+' !important;}',
            '.alert-danger{background-color:'+c.danger+'22 !important;border-color:'+c.danger+'66 !important;color:'+c.danger+' !important;}',
            '.alert-warning{background-color:'+c.warning+'22 !important;border-color:'+c.warning+'66 !important;color:'+c.warning+'cc !important;}',
            '.alert-info{background-color:'+c.info+'22 !important;border-color:'+c.info+'66 !important;color:'+c.info+' !important;}',
            '.alert-primary{background-color:'+c.primary+'22 !important;border-color:'+c.primary+'66 !important;color:'+c.primary+' !important;}',

            /* ── FORMULARIOS ── */
            '.form-control:focus,.form-select:focus{border-color:'+c.accent+' !important;box-shadow:0 0 0 .2rem '+c.accent+'33 !important;}',
            '.form-check-input:checked{background-color:'+c.primary+' !important;border-color:'+c.primary+' !important;}',

            /* ── PROGRESS BARS ── */
            '.progress-bar{background-color:'+c.primary+' !important;}',
            '.progress-bar.bg-success{background-color:'+c.success+' !important;}',
            '.progress-bar.bg-danger{background-color:'+c.danger+' !important;}',
            '.progress-bar.bg-warning{background-color:'+c.warning+' !important;}',
            '.progress-bar.bg-info{background-color:'+c.info+' !important;}',

            /* ── MODALES ── */
            '.modal-header.bg-primary{background-color:'+c.primary+' !important;}',
            '.modal-header.bg-danger{background-color:'+c.danger+' !important;}',
            '.modal-header.bg-success{background-color:'+c.success+' !important;}',
            '.modal-header.bg-warning{background-color:'+c.warning+' !important;}',
            '.modal-content{background:'+c.cardBg+' !important;border-color:'+c.border+' !important;}',

            /* ── PAGINACIÓN ── */
            '.page-link{color:'+c.primary+' !important;}',
            '.page-item.active .page-link{background-color:'+c.primary+' !important;border-color:'+c.primary+' !important;color:#fff !important;}',

            /* ── LINKS ── */
            'a:not(.btn):not(.nav-link):not(.navbar-brand):not(.dropdown-item){color:'+c.link+' !important;}',
            'a:not(.btn):not(.nav-link):not(.navbar-brand):not(.dropdown-item):hover{color:'+c.accent+' !important;}',

            /* ── TEXTOS ── */
            '.text-primary{color:'+c.primary+' !important;}',
            '.text-success{color:'+c.success+' !important;}',
            '.text-danger{color:'+c.danger+' !important;}',
            '.text-warning{color:'+c.warning+' !important;}',
            '.text-info{color:'+c.info+' !important;}',
            '.text-muted{color:'+c.textMuted+' !important;}',

            /* ── BG COLORES ── */
            '.bg-primary{background-color:'+c.primary+' !important;}',
            '.bg-success{background-color:'+c.success+' !important;}',
            '.bg-danger{background-color:'+c.danger+' !important;}',
            '.bg-warning{background-color:'+c.warning+' !important;}',
            '.bg-info{background-color:'+c.info+' !important;}',
            '.bg-light{background-color:'+c.cardBg+' !important;}',

            /* ── BORDES ── */
            '.border-primary{border-color:'+c.primary+' !important;}',
            '.border-success{border-color:'+c.success+' !important;}',
            '.border-danger{border-color:'+c.danger+' !important;}',
            '.border-warning{border-color:'+c.warning+' !important;}',
            '.border-info{border-color:'+c.info+' !important;}',
            '.border-top,.border-bottom,.border{border-color:'+c.border+' !important;}',

            /* ── LIST GROUPS ── */
            '.list-group-item-action:hover{background:'+c.primary+'11 !important;}',
            '.list-group-item.active{background-color:'+c.primary+' !important;border-color:'+c.primary+' !important;}',

            /* ── INPUT GROUP ── */
            '.input-group-text{background-color:'+c.pageBg+' !important;border-color:'+c.border+' !important;color:'+c.textMuted+' !important;}',

            /* ── FOOTER ── */
            'footer.footer{border-color:'+c.border+' !important;color:'+c.textMuted+' !important;}',
            'footer.footer a{color:'+c.link+' !important;}',

        ].join('');

        var s = document.createElement('style');
        s.id = 'ventaapp-theme-v2';
        document.head.appendChild(s);
        s.textContent = css;

    } catch(e) { console.warn('VentaApp theme error:', e); }
})();
</script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-body-tertiary" data-bs-theme = "dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop"></i> VentaApp
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarScroll" aria-controls="navbarScroll" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarScroll">
                <ul class="navbar-nav me-auto my-2 my-lg-0 navbar-nav-scroll" style="--bs-scroll-height: 100px;">
                        
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Inicio
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Clientes" asp-action="Index">
                            <i class="bi bi-people"></i> Clientes
                        </a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-box-seam"></i> Productos
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Productos" asp-action="Index">
                                <i class="bi bi-list"></i> Ver Productos
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Productos" asp-action="Create">
                                <i class="bi bi-plus-circle"></i> Agregar Producto
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#">
                                <i class="bi bi-gear"></i> Categorías
                            </a></li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Ventas" asp-action="Index">
                            <i class="bi bi-cart"></i> Ventas
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Facturas" asp-action="Index">
                            <i class="bi bi-file-earmark-text"></i> Facturas
                        </a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-gear"></i> Configuracion
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index">
                                <i class="bi bi-list"></i> Usuarios
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Ajustes" asp-action="Editar">
                                <i class="bi bi-plus-circle"></i> Ajustes
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#">
                                <i class="bi bi-gear"></i> FeedBack
                            </a></li>
                        </ul>
                    </li>
                    
                </ul>

                    <ul class="navbar-nav ms-auto">
                        <partial name="LoginPartial" />
                    </ul>

                <form class="d-flex" role="search">
                    <input class="form-control me-2" type="search" placeholder="Buscar..." aria-label="Search"/>
                    <button class="btn btn-outline-success" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>
        </nav> 
    </header>
    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; 2026 - VentaApp - Sistema de Gestión de Ventas - 
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>
    
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
