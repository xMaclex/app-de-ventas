/* ===================================================
   ESTADO
=================================================== */
const DEFAULT = {
    navBg:'#212529', navText:'#ffffff', navBrand:'#ffffff', dropBg:'#ffffff',
    primary:'#0d6efd', accent:'#0d6efd', success:'#198754', danger:'#dc3545', warning:'#ffc107', info:'#0dcaf0',
    pageBg:'#f8f9fa', cardBg:'#ffffff', tableHead:'#212529', border:'#dee2e6',
    textMain:'#212529', textMuted:'#6c757d', link:'#0d6efd', opacity:100
};

let current = Object.assign({}, DEFAULT);

/* ===================================================
   INIT
=================================================== */
document.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('ventaapp_palette_v2');
    if (saved) { try { Object.assign(current, JSON.parse(saved)); } catch(e){} }
    renderPresets();
    bindAllControls();
    syncAllInputs();
    updatePreview();
    updateCode();
    aplicarAlDOM(current);
});

/* ===================================================
   TABS
=================================================== */
function showTab(id, el) {
    document.querySelectorAll('.color-section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.color-tab').forEach(t => t.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    el.classList.add('active');
}

/* ===================================================
   PRESETS
=================================================== */
function renderPresets() {
    const grid = document.getElementById('presetGrid');
    grid.innerHTML = '';
    PRESETS.forEach((p, i) => {
        const div = document.createElement('div');
        div.className = 'preset-card';
        div.id = 'preset_' + i;
        div.innerHTML = `<div class="preset-bar"><span style="background:${p.navBg}"></span><span style="background:${p.primary}"></span><span style="background:${p.accent}"></span></div><span class="preset-name">${p.name}</span>`;
        div.addEventListener('click', () => {
            Object.assign(current, p);
            syncAllInputs();
            updatePreview();
            updateCode();
            document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
            div.classList.add('active');
        });
        grid.appendChild(div);
    });
}

/* ===================================================
   BIND CONTROLES
=================================================== */
const CONTROL_MAP = [
    ['clrNavBg',    'hexNavBg',    'navBg'],
    ['clrNavText',  'hexNavText',  'navText'],
    ['clrNavBrand', 'hexNavBrand', 'navBrand'],
    ['clrDropBg',   'hexDropBg',   'dropBg'],
    ['clrPrimary',  'hexPrimary',  'primary'],
    ['clrAccent',   'hexAccent',   'accent'],
    ['clrSuccess',  'hexSuccess',  'success'],
    ['clrDanger',   'hexDanger',   'danger'],
    ['clrWarning',  'hexWarning',  'warning'],
    ['clrInfo',     'hexInfo',     'info'],
    ['clrPageBg',   'hexPageBg',   'pageBg'],
    ['clrCardBg',   'hexCardBg',   'cardBg'],
    ['clrTableHead','hexTableHead','tableHead'],
    ['clrBorder',   'hexBorder',   'border'],
    ['clrTextMain', 'hexTextMain', 'textMain'],
    ['clrTextMuted','hexTextMuted','textMuted'],
    ['clrLink',     'hexLink',     'link'],
];

function bindAllControls() {
    CONTROL_MAP.forEach(([clrId, hexId, key]) => {
        const clr = document.getElementById(clrId);
        const hex = document.getElementById(hexId);
        if (!clr || !hex) return;
        clr.addEventListener('input', () => {
            current[key] = clr.value;
            hex.value = clr.value.toUpperCase();
            updatePreview(); updateCode();
            document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
        });
        hex.addEventListener('input', () => {
            if (/^#[0-9A-Fa-f]{6}$/.test(hex.value)) {
                current[key] = hex.value;
                clr.value = hex.value;
                updatePreview(); updateCode();
                document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
            }
        });
    });

    const slider = document.getElementById('sliderOpacity');
    slider.addEventListener('input', () => {
        current.opacity = parseInt(slider.value);
        document.getElementById('opacityVal').textContent = slider.value + '%';
        updatePreview(); updateCode();
    });
}

function syncAllInputs() {
    CONTROL_MAP.forEach(([clrId, hexId, key]) => {
        const clr = document.getElementById(clrId);
        const hex = document.getElementById(hexId);
        if (clr) clr.value = current[key] || '#ffffff';
        if (hex) hex.value = (current[key] || '#ffffff').toUpperCase();
    });
    const sl = document.getElementById('sliderOpacity');
    if (sl) { sl.value = current.opacity || 100; document.getElementById('opacityVal').textContent = (current.opacity||100)+'%'; }
}

/* ===================================================
   PREVIEW
=================================================== */
function hexToRgb(h) {
    return `${parseInt(h.slice(1,3),16)},${parseInt(h.slice(3,5),16)},${parseInt(h.slice(5,7),16)}`;
}

function updatePreview() {
    const op = (current.opacity||100)/100;
    const rgb = hexToRgb(current.navBg);

    // Navbar
    const nav = document.getElementById('navPreview');
    nav.style.background = `rgba(${rgb},${op})`;
    document.getElementById('prevBrand').style.color = current.navBrand;
    ['prevLink1','prevLink3'].forEach(id => {
        document.getElementById(id).style.color = current.navText;
        document.getElementById(id).style.background = 'transparent';
    });
    document.getElementById('prevLink2').style.color = current.accent;
    document.getElementById('prevLink2').style.background = current.accent+'22';
    document.getElementById('prevUser').style.color = current.navText;

    // Page bg
    document.getElementById('pagePreview').style.background = current.pageBg;

    // Buttons
    setStyle('prevBtnPrimary', { background: current.primary, color: '#fff' });
    setStyle('prevBtnSuccess', { background: current.success, color: '#fff' });
    setStyle('prevBtnDanger',  { background: current.danger,  color: '#fff' });
    setStyle('prevBtnWarning', { background: current.warning, color: '#000' });

    // Badges
    setStyle('prevBadgePrimary', { background: current.primary+'22', color: current.primary });
    setStyle('prevBadgeSuccess', { background: current.success+'22', color: current.success });
    setStyle('prevBadgeDanger',  { background: current.danger+'22',  color: current.danger  });
    setStyle('prevBadgeInfo',    { background: current.info+'22',    color: current.info    });

    // Link
    document.getElementById('prevLink').style.color = current.link;

    // Cards header
    document.getElementById('prevCardH1').style.background = current.primary;
    document.getElementById('prevCardH2').style.background = current.success;

    // Progress
    document.getElementById('prevProgressFill').style.background = current.primary;
    document.getElementById('prevTableLabel').style.color = current.textMain;
    document.getElementById('prevTableValue').style.color = current.primary;
}

function setStyle(id, styles) {
    const el = document.getElementById(id);
    if (!el) return;
    Object.assign(el.style, styles);
}

/* ===================================================
   CÓDIGO
=================================================== */
function updateCode() {
    document.getElementById('codigoPaleta').value = JSON.stringify(current, null, 2);
}

/* ===================================================
